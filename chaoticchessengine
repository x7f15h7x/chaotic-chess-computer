def judge_the_position(current_game: chess.Board) -> float:
    worth = {chess.PAWN: 100, chess.KNIGHT: 320, chess.BISHOP: 330, chess.ROOK: 500, chess.QUEEN: 900, chess.KING: 20000}
    
    piece_total = sum(
        (worth.get(item.piece_type, 0) * (1 if item.color == chess.WHITE else -1))
        for item in current_game.piece_map().values()
    )
    
    hot_spots = [chess.D4, chess.D5, chess.E4, chess.E5]
    middle_boost = sum(
        15 if current_game.piece_at(spot) and current_game.piece_at(spot).color == current_game.turn else -5
        for spot in hot_spots
    )
    
    wild_factor = random.gauss(0, 50 if current_game.is_check() else 30)
    
    return float(piece_total + middle_boost + wild_factor)

def scan_moves(current_game: chess.Board, steps_left: int, bottom: float, top: float) -> float:
    if steps_left == 0 or current_game.is_game_over():
        return judge_the_position(current_game)
    
    if current_game.turn == chess.WHITE:
        top_score = -inf
        for option in current_game.legal_moves:
            current_game.push(option)
            result = scan_moves(current_game, steps_left - 1, bottom, top)
            current_game.pop()
            top_score = max(top_score, result)
            bottom = max(bottom, result)
            if top <= bottom:
                break
        return top_score
    else:
        low_score = inf
        for option in current_game.legal_moves:
            current_game.push(option)
            result = scan_moves(current_game, steps_left - 1, bottom, top)
            current_game.pop()
            low_score = min(low_score, result)
            top = min(top, result)
            if top <= bottom:
                break
        return low_score

# computer picks its next action - checks options then randomly picks from the decent ones
def decide_computer_move(current_game: chess.Board, depth=3, randomness=0.8) -> chess.Move | None:
    if current_game.is_game_over():
        return None
    
    choices = list(current_game.legal_moves)
    if not choices:
        return None
    
    results = []
    is_white_turn_now = current_game.turn == chess.WHITE
    
    for pick in choices:
        current_game.push(pick)
        base = scan_moves(current_game, depth - 1, -inf, inf)
        current_game.pop()
        
        if not is_white_turn_now:
            base = -base
        results.append(base)
    
    if randomness <= 0.01:
        return choices[results.index(max(results))]
    
    peak = max(results)
    boosted = [math.exp((val - peak) / randomness) for val in results]
    combined = sum(boosted)
    odds = [b / combined for b in boosted]
    
    selected = random.choices(range(len(choices)), weights=odds, k=1)[0]
    return choices[selected]

def show_chessboard(current_game: chess.Board) -> None:
    print("    a b c d e f g h")
    for rank in range(7, -1, -1):
        row = f"{rank + 1}  "
        for file in range(8):
            pos = chess.square(file, rank)
            thing = current_game.piece_at(pos)
            row += (thing.symbol() if thing else ".") + " "
        print(row)
    print("    a b c d e f g h\n")

